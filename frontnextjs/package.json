{
  "name": "frontnextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:ci": "jest --runInBand --ci --passWithNoTests",
    "audit": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix || npm audit --audit-level=high"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "next": "15.5.12"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@tailwindcss/postcss": "^4",
    "tailwindcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "15.5.12",
    "@eslint/eslintrc": "^3",
    "jest": "^29",
    "jest-environment-jsdom": "^29",
    "@types/jest": "^29",
    "ts-jest": "^29",
    "@testing-library/react": "^16",
    "@testing-library/jest-dom": "^6",
    "@testing-library/user-event": "^14"
  }
}
